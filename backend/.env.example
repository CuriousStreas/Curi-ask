# 聚合 API 基础地址（无默认值，必填）
# 示例：https://poloapi.top（若第三方要求追加路径，可在此直接写完整 base，或通过 AI_CHAT_PATH 配置）
AI_API_BASE_URL=https://poloapi.top

# 鉴权密钥：放在请求头 Header 的 Authorization: Bearer <key>
AI_API_KEY=SK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 聊天接口路径（可选）。最终请求 = AI_API_BASE_URL + AI_CHAT_PATH
# 默认 /v1/chat/completions；若 base 已含 /v1，可改为 /chat/completions 或按文档填写
# AI_CHAT_PATH=/v1/chat/completions

# 模型列表（可选）。逗号分隔，不填则前端下拉为空，需你自行配置可用模型
# AI_MODELS=model-a,model-b

# 服务端口
PORT=3001
