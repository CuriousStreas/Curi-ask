# Curi Ask - Nginx 反向代理示例
# 使用：复制为 nginx.conf 或放入 conf.d/，根据路径修改后 nginx -t && nginx -s reload

worker_processes auto;
events { worker_connections 1024; }

http {
    include       mime.types;
    default_type application/octet-stream;
    sendfile      on;
    keepalive_timeout 65;

    # 可选：限流，防刷
    limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;
    limit_req_zone $binary_remote_addr zone=chat:10m rate=2r/s;

    server {
        listen 80;
        server_name localhost;   # 改成你的域名或 IP

        # 前端静态（若已 build）
        location / {
            root   /path/to/Curi-ask/frontend/dist;
            index  index.html;
            try_files $uri $uri/ /index.html;
        }

        # 后端 API：只暴露给 Nginx，不直接对外
        location /api/ {
            proxy_pass http://127.0.0.1:3001;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # 限流（可选）：API 10req/s，对话 2req/s
            limit_req zone=api burst=20 nodelay;
        }
        location /api/chat {
            limit_req zone=chat burst=5 nodelay;
            proxy_pass http://127.0.0.1:3001;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}
